---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const { title = "Primavera Journeys — Bespoke Medellín Tours", description = "Primavera Journeys designs deeply personal, bespoke tours of Medellín for singles, couples, and groups. Crafted around who you are, not a fixed itinerary." } = Astro.props;
---
<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <title>{title}</title>
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "Primavera Journeys",
      "description": "Primavera Journeys designs deeply personal, bespoke tours of Medellín for singles, couples, and groups — crafted around who you are, not a fixed itinerary.",
      "url": "https://medell-n-bespoke-tours.onrender.com"
    }
    </script>
  </head>
  <body class="min-h-screen flex flex-col bg-surface-50 text-surface-900 font-body antialiased">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
