---
const year = new Date().getFullYear();
---
<footer class="bg-surface-950 text-surface-50">
  <!-- Wave top divider -->
  <div class="overflow-hidden leading-[0]">
    <svg viewBox="0 0 1440 60" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none" class="w-full h-12 block" style="background: oklch(0.985 0.012 85);">
      <path d="M0,30 C360,60 1080,0 1440,30 L1440,60 L0,60 Z" fill="oklch(0.15 0.045 152)"/>
    </svg>
  </div>

  <div class="max-w-6xl mx-auto px-6 lg:px-8 py-14">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10">

      <!-- Brand -->
      <div>
        <div class="flex items-center gap-2.5 mb-4">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" class="text-accent-400">
            <path d="M12 2C12 2 4 6 4 13C4 17.4183 7.58172 21 12 21C16.4183 21 20 17.4183 20 13C20 6 12 2 12 2Z" fill="currentColor" fill-opacity="0.25"/>
            <path d="M12 2C12 2 4 6 4 13C4 17.4183 7.58172 21 12 21C16.4183 21 20 17.4183 20 13C20 6 12 2 12 2Z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
            <path d="M12 21V10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            <path d="M12 14L8.5 10.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            <path d="M12 17L15.5 13.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
          <span class="font-display text-lg font-semibold text-surface-50">Primavera Journeys</span>
        </div>
        <p class="text-sm text-surface-300 leading-relaxed">
          Medellín, made just for you.<br/>Bespoke tours crafted by local experts who know every corner, story, and secret.
        </p>
      </div>

      <!-- Links -->
      <div>
        <h4 class="text-xs font-medium tracking-widest uppercase text-surface-400 mb-4">Explore</h4>
        <ul class="space-y-2.5">
          <li><a href="#why" class="text-sm text-surface-300 hover:text-accent-400 transition-colors duration-150">Our Story</a></li>
          <li><a href="#experiences" class="text-sm text-surface-300 hover:text-accent-400 transition-colors duration-150">Experiences</a></li>
          <li><a href="#how" class="text-sm text-surface-300 hover:text-accent-400 transition-colors duration-150">How It Works</a></li>
          <li><a href="#contact" class="text-sm text-surface-300 hover:text-accent-400 transition-colors duration-150">Plan My Journey</a></li>
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h4 class="text-xs font-medium tracking-widest uppercase text-surface-400 mb-4">Get in Touch</h4>
        <ul class="space-y-2.5">
          <li>
            <a href="mailto:hello@primaverajourneys.co" class="text-sm text-surface-300 hover:text-accent-400 transition-colors duration-150 flex items-center gap-2">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
              hello@primaverajourneys.co
            </a>
          </li>
          <li>
            <span class="text-sm text-surface-300 flex items-center gap-2">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
              Medellín, Colombia
            </span>
          </li>
          <li>
            <a href="https://wa.me/573001234567" class="text-sm text-surface-300 hover:text-accent-400 transition-colors duration-150 flex items-center gap-2">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/></svg>
              WhatsApp us
            </a>
          </li>
        </ul>
      </div>
    </div>

    <div class="mt-12 pt-8 border-t border-surface-800 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-xs text-surface-500">&copy; {year} Primavera Journeys. All rights reserved.</p>
      <p class="text-xs text-surface-600 italic font-display">Medellín, made just for you.</p>
    </div>
  </div>
</footer>
